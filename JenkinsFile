pipeline{
    agent { label 'agent'}
    stages{
        stage('Checkout'){
            steps{
                checkout([
                        $class: 'GitSCM',
                        branches:[[name: '*/main']],
                        userRemoteConfig:[[
                                                  url: 'https://github.com/zeeshanmys98/sample-webapp.git', credentialId: 'github_token'
                                          ]]
                ])
            }
        }
        stage('Build'){
            steps {
                sh '''mvn clean install'''
            }
        }
        stage('Test'){
            steps{
                sh '''
                mvn test
                '''
            }
        }
        stage('Deploy To ArtiFactory') {
            steps {
                configFileProvider([configFile(fileId: '82f80c51-a4d1-4343-9df3-14fff9de520f' , variable: 'MAVEN_SETTINGS')]){
                    sh '''
                    mvn deploy -s $MAVEN_SETTINGS
                    '''
                }
            }
        }
        stage('Deploy war to Tomcat') {
            steps {
                sh '''
                echo "copying to tomcat "
                if curl -s -o /dev/null -w "%{http_code}" http://51.21.196.63:8080/ | grep -q "200"; then
                sudo /usr/tomcat/tomcat10/bin/shutdown.sh
                cp /home/ubuntu/workspace/first-project/target/StudentManagementApp-1.1-SNAPSHOT.war /usr/tomcat/tomcat10/webapps
                sudo /usr/tomcat/tomcat10/bin/startup.sh
                else
                cp /home/ubuntu/workspace/first-project/target/StudentManagementApp-1.1-SNAPSHOT.war /usr/tomcat/tomcat10/webapps
                sudo /usr/tomcat/tomcat10/bin/startup.sh
                fi
                '''
            }
        }
    }
}